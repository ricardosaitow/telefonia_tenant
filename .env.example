# ---------------------------------------------------------------------------
# .env.example — placeholders. Copiar pra .env (git-ignored) e preencher.
# Em produção, valores reais vêm do Infisical via getSecret(); só
# INFISICAL_SERVICE_TOKEN, AUTH_URL, NODE_ENV moram em env de fato.
# ---------------------------------------------------------------------------

# === Banco ===
# Runtime: app_user (non-superuser, RLS aplicada). Porta 5444 = Postgres dev do portal.
DATABASE_URL="postgresql://app_user:dev_password@localhost:5444/portal_dev?schema=public"
# Migrations: superuser, criação de schema, GRANTs. Nunca usado em runtime.
DATABASE_URL_MIGRATE="postgresql://postgres:dev_password@localhost:5444/portal_dev?schema=public"

# === Ambiente ===
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# === Auth ===
# Gerar com: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"
AUTH_URL="http://localhost:3000"

# === Infisical ===
INFISICAL_SERVICE_TOKEN="st.xxx.xxx"
INFISICAL_SITE_URL="https://secrets.pekiart.com.br"
INFISICAL_PROJECT_ID="CHANGE_ME"
INFISICAL_ENVIRONMENT="dev"

# === Email (Resend — transacional) ===
RESEND_API_KEY=""
EMAIL_FROM="noreply@pekiart.com.br"

# === Channel Credentials ===
# AES-256-GCM key for SMTP/IMAP/POP3 password encryption. Generate with: openssl rand -hex 32
CHANNEL_ENCRYPTION_KEY=""

# === Cron ===
# Bearer token for /api/cron/* routes. Generate with: openssl rand -base64 32
CRON_BEARER_TOKEN=""

# === Logs ===
LOG_LEVEL="debug"

# === FusionPBX (data plane SIP) ===
# Postgres interno do FusionPBX. Em dev local, host alcança a defaultnet
# Docker (172.31.0.0/16) por routing direto. Senha vem do
# secrets/fusionpbx_db_password.txt no repo telefonia-ia.
FUSIONPBX_DB_URL="postgresql://fusionpbx:CHANGE_ME@172.31.0.30:5432/fusionpbx"
# ESL (Event Socket Library) — usado pra reloadxml após escrita em v_*.
FUSIONPBX_ESL_HOST="172.31.0.31"
FUSIONPBX_ESL_PORT="8021"
FUSIONPBX_ESL_PASSWORD="ClueCon"
