// Schema do portal — control plane SaaS multi-tenant.
// Canônico do modelo de dados: /root/telefonia-ia/docs/ontologia.md
// ADRs relevantes: D002 (RLS), D004 (Account global ↔ Membership N:N), D008 (MFA), D009 (segredos só refs).
//
// Convenções:
//   - PascalCase nas models, camelCase nos campos.
//   - @map("snake_case") em todos os campos; @@map em snake_case plural.
//   - PK: UUIDv7 (ordenado, melhor pra B-tree e cursor pagination).
//   - Timestamps: createdAt/updatedAt em todas as entidades.
//   - Toda tabela com tenantId: @@index([tenantId]) + RLS via SQL na migration (D002).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma 7: `url` no schema foi removida. URL de migrate vive em prisma.config.ts;
// runtime usa adapter (@prisma/adapter-pg) com URL passada ao PrismaClient.
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Account — identidade global. NÃO pertence a tenant (D004).
// Email único globalmente; mesma Account pode ter N TenantMembership.
// MFA campos preparados (D008): habilitação real vem com fluxo NextAuth.
// Segredos (mfa_*_ref) são paths Infisical, NUNCA o valor (D009).
// ---------------------------------------------------------------------------
model Account {
  id                 String        @id @default(uuid(7)) @db.Uuid
  email              String        @unique
  passwordHash       String        @map("password_hash")
  nome               String
  locale             String        @default("pt-BR")
  status             AccountStatus @default(active)

  // MFA — refs Infisical, sem valor em claro.
  mfaEnabled         Boolean       @default(false) @map("mfa_enabled")
  mfaSecretRef       String?       @map("mfa_secret_ref")
  mfaBackupCodesRef  String?       @map("mfa_backup_codes_ref")

  // Lockout / brute-force.
  failedLoginCount   Int           @default(0) @map("failed_login_count")
  lockoutUntil       DateTime?     @map("lockout_until") @db.Timestamptz(6)
  lastLoginAt        DateTime?     @map("last_login_at") @db.Timestamptz(6)

  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships        TenantMembership[]
  sessions           Session[]
  publishedAgentVersions AgentVersion[]
  auditLogs          AuditLog[]
  securityEvents     SecurityEvent[]
  conversationInterventions ConversationIntervention[]
  turnsAsActor       Turn[]

  @@map("accounts")
}

enum AccountStatus {
  active
  disabled
  locked

  @@map("account_status")
}

// ---------------------------------------------------------------------------
// Tenant — empresa cliente. RLS aplicada no `id` (não há coluna `tenant_id` aqui).
// Listagem pré-tenant (lookup de memberships do user logado) é feita por role
// administrativo controlado — runtime padrão NUNCA enxerga tenants alheios.
// ---------------------------------------------------------------------------
model Tenant {
  id                    String       @id @default(uuid(7)) @db.Uuid
  slug                  String       @unique
  nomeFantasia          String       @map("nome_fantasia")
  razaoSocial           String?      @map("razao_social")
  cnpj                  String?      @unique
  dominioEmailPrincipal String?      @map("dominio_email_principal")
  defaultLocale         String       @default("pt-BR") @map("default_locale")
  status                TenantStatus @default(trial)

  // Plano ativo do tenant — slug de referência (constante em código, não FK).
  // Default "demo" pra manter compatibilidade. Quando billing vier, migramos
  // pra model Subscription (avaliação futura).
  planSlug              String       @default("demo") @map("plan_slug")
  trialEndsAt           DateTime?    @map("trial_ends_at") @db.Timestamptz(6)

  // FK pra v_domains.domain_uuid no Postgres do FusionPBX (cross-DB, sem FK
  // formal). Nullable: tenant pode existir antes da integração ser provisionada.
  // @unique evita 2 tenants apontarem pro mesmo Domain do PBX.
  pbxDomainUuid         String?      @unique @map("pbx_domain_uuid") @db.Uuid

  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships           TenantMembership[]
  activeSessions        Session[]          @relation("SessionActiveTenant")
  departments           Department[]
  agents                Agent[]
  agentVersions         AgentVersion[]
  auditLogs             AuditLog[]
  channels              Channel[]
  extensions            Extension[]
  routingRules          RoutingRule[]
  knowledgeSources      KnowledgeSource[]
  agentTools            AgentTool[]
  messageTemplates      MessageTemplate[]
  conversations         Conversation[]
  turns                 Turn[]
  securityEvents        SecurityEvent[]
  usageRecords          UsageRecord[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// Extension — ramal SIP interno do tenant (1001, 1002, ...). Provisionado
// no FusionPBX (tabela v_extensions). Portal é fonte de verdade lógica;
// FusionPBX é o data plane que serve registers/calls.
//
// Senha SIP NUNCA em claro (D009). passwordRef aponta pra path Infisical
// `/tenants/<slug>/sip/<extension>` (ou env var em dev).
// pbxExtensionUuid: FK lógica pra v_extensions.extension_uuid; nullable
// até provisioning concluir.
//
// extensionNumber é único PER tenant — 2 tenants podem ter "1001".
// RLS por tenant_id (D002).
// ---------------------------------------------------------------------------
model Extension {
  id                String   @id @default(uuid(7)) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid

  extension         String                                                       // "1001", "2003", etc
  displayName       String?  @map("display_name")                                // "Recepção", "João - Vendas"
  passwordRef       String   @map("password_ref")                                // Infisical path
  pbxExtensionUuid  String?  @unique @map("pbx_extension_uuid") @db.Uuid

  enabled           Boolean  @default(true)

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, extension])
  @@index([tenantId])
  @@map("extensions")
}

enum TenantStatus {
  trial
  active
  suspended
  canceled

  @@map("tenant_status")
}

// ---------------------------------------------------------------------------
// TenantMembership — vínculo Account ↔ Tenant (M:N). Carrega papel global.
// RLS por tenant_id. Papéis por departamento ficam em `membership_department_role` (V1.x).
// ---------------------------------------------------------------------------
model TenantMembership {
  id            String           @id @default(uuid(7)) @db.Uuid
  tenantId      String           @map("tenant_id") @db.Uuid
  accountId     String           @map("account_id") @db.Uuid
  status        MembershipStatus @default(invited)
  globalRole    MembershipRole   @map("global_role")

  joinedAt      DateTime?        @map("joined_at") @db.Timestamptz(6)
  lastActiveAt  DateTime?        @map("last_active_at") @db.Timestamptz(6)

  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account       Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  auditLogs     AuditLog[]

  @@unique([tenantId, accountId])
  @@index([tenantId])
  @@index([accountId])
  @@map("tenant_memberships")
}

enum MembershipStatus {
  invited
  active
  disabled

  @@map("membership_status")
}

enum MembershipRole {
  tenant_owner
  tenant_admin
  department_supervisor
  operator
  auditor

  @@map("membership_role")
}

// ---------------------------------------------------------------------------
// Session — sessão de Account (D008/seguranca.md §6.2). Strategy híbrida:
// NextAuth força `jwt` quando há provider Credentials, mas guardamos a sessão
// no DB pra preservar revogação imediata. O JWT carrega só `sessionToken`
// opaco; callback `session` valida contra esta tabela a cada request.
// SEM tenantId → SEM RLS. Sessão é por-Account, atravessa tenants (a seleção
// de tenant ativo vive no JWT/cookie separado, vem em 8c).
// ---------------------------------------------------------------------------
model Session {
  id             String    @id @default(uuid(7)) @db.Uuid
  sessionToken   String    @unique @map("session_token")
  accountId      String    @map("account_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(6)
  ip             String?
  userAgent      String?   @map("user_agent")

  // Tenant ativo da sessão (nullable: usuário acabou de logar e ainda não escolheu;
  // ou tenant foi removido — onDelete: SetNull preserva sessão sem tenant).
  // Trocar de tenant = update este campo. Próxima request lê o novo via callback session.
  activeTenantId String?   @map("active_tenant_id") @db.Uuid

  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  account        Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  activeTenant   Tenant?   @relation("SessionActiveTenant", fields: [activeTenantId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([expiresAt])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Department — agrupa Agents por área (Comercial, Suporte N1/N2/N3, Financeiro).
// Ontologia §5. RLS por tenant_id (D002).
// ---------------------------------------------------------------------------
model Department {
  id                      String   @id @default(uuid(7)) @db.Uuid
  tenantId                String   @map("tenant_id") @db.Uuid
  slug                    String
  nome                    String
  descricao               String?
  cor                     String?  // hex/CSS, UI-only — validação no Zod
  // business_hours: JSON com { dias: [...], horas: { abre, fecha }, timezone }.
  // Schema é livre na V1 (validação no app); endurece quando o produto pedir.
  businessHours           Json?    @map("business_hours")
  outOfHoursTemplateKey   String?  @map("out_of_hours_template_key")
  // FK opcional pra Agent default; circular ref com Agent (Agent.departmentId).
  // onDelete: SetNull pra que apagar Agent não derrube Department.
  defaultAgentId          String?  @map("default_agent_id") @db.Uuid

  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultAgent            Agent?   @relation("DepartmentDefaultAgent", fields: [defaultAgentId], references: [id], onDelete: SetNull)
  agents                  Agent[]  @relation("DepartmentAgents")
  routingRulesAsTarget    RoutingRule[] @relation("RoutingRuleTargetDepartment")
  conversationsAsCurrent  Conversation[] @relation("ConversationCurrentDepartment")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("departments")
}

// ---------------------------------------------------------------------------
// Agent — IA configurada pra função num Department (Ontologia §6, D005).
//
// Versionamento híbrido (D005):
//   - draft_state: JSON com (system_prompt, params, tools_config) em rascunho.
//     Atualizado por autosave durante edição. NÃO versionado.
//   - currentVersionId: FK pra última AgentVersion publicada — runtime sempre
//     lê esta. Nullable até primeira publish.
//   - status: draft → testing → production → paused; volta a production.
//
// RLS por tenant_id (D002).
// ---------------------------------------------------------------------------
model Agent {
  id                String        @id @default(uuid(7)) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  departmentId     String        @map("department_id") @db.Uuid
  slug              String
  nome              String
  descricao         String?

  // Estado mutável (autosave). Validado por Zod no app antes de publicar.
  draftState        Json          @default("{}") @map("draft_state")
  status            AgentStatus   @default(draft)

  // Versão publicada que o runtime executa. Nullable até primeira publish.
  // onDelete: Restrict pra que não se possa apagar versão sendo usada — quem
  // tentar precisa primeiro mover currentVersionId.
  currentVersionId  String?       @unique @map("current_version_id") @db.Uuid
  lastPublishedAt   DateTime?     @map("last_published_at") @db.Timestamptz(6)

  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department        Department    @relation("DepartmentAgents", fields: [departmentId], references: [id], onDelete: Restrict)
  defaultOf         Department[]  @relation("DepartmentDefaultAgent")

  versions          AgentVersion[] @relation("AgentVersions")
  currentVersion    AgentVersion?  @relation("AgentCurrentVersion", fields: [currentVersionId], references: [id], onDelete: Restrict)

  routingRulesAsTarget RoutingRule[] @relation("RoutingRuleTargetAgent")
  tools                AgentTool[]
  conversationsAsCurrent Conversation[] @relation("ConversationCurrentAgent")
  conversationAgentHistoryFrom ConversationAgentHistory[] @relation("ConversationAgentHistoryFrom")
  conversationAgentHistoryTo   ConversationAgentHistory[] @relation("ConversationAgentHistoryTo")
  usageRecords         UsageRecord[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([departmentId])
  @@map("agents")
}

enum AgentStatus {
  draft
  testing
  production
  paused

  @@map("agent_status")
}

// ---------------------------------------------------------------------------
// AgentVersion — snapshot imutável publicado (D005, Ontologia §7).
//
// Runtime SEMPRE lê via Agent.currentVersionId. Imutável após criação:
// rollback = nova publish que copia snapshot antigo pro draft + republica.
//
// `version` é incremental por Agent (1, 2, 3...). Garantido por @@unique +
// lógica de incremento na Server Action de publish.
//
// RLS por tenant_id denormalizado (não tem na tabela mãe — Agent — então
// guardamos cópia aqui pra a policy funcionar sem JOIN).
// ---------------------------------------------------------------------------
model AgentVersion {
  id                      String    @id @default(uuid(7)) @db.Uuid
  agentId                 String    @map("agent_id") @db.Uuid
  tenantId                String    @map("tenant_id") @db.Uuid
  version                 Int

  publishedAt             DateTime  @default(now()) @map("published_at") @db.Timestamptz(6)
  publishedByAccountId    String?   @map("published_by_account_id") @db.Uuid

  systemPrompt            String    @map("system_prompt")
  params                  Json
  toolsSnapshot           Json      @map("tools_snapshot")
  knowledgeSnapshot       Json      @map("knowledge_snapshot")
  changelog               String?

  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent                   Agent     @relation("AgentVersions", fields: [agentId], references: [id], onDelete: Cascade)
  publishedByAccount      Account?  @relation(fields: [publishedByAccountId], references: [id], onDelete: SetNull)
  agentAsCurrent          Agent?    @relation("AgentCurrentVersion")

  @@unique([agentId, version])
  @@index([tenantId])
  @@index([agentId])
  @@map("agent_versions")
}

// ---------------------------------------------------------------------------
// AuditLog — registro append-only de ações privilegiadas (Ontologia §17,
// docs/seguranca.md §5.7).
//
// Granularidade: 1 row por ação significativa (CRUD em entidade de
// configuração, publish, mudança de role, conexão de integração, login...).
// `action` é string composta tipo "department.create", "agent.publish".
// `before`/`after` carregam JSON da entidade antes/depois (omitir senão).
//
// Cobertura V1: ações dentro de tenant (todas têm tenant_id obrigatório).
// Eventos cross-tenant (login, signup global) ficam pra SecurityEvent
// quando essa tabela for criada.
//
// Hash chain (anti-tampering, seguranca.md §5.7) fica pra V1.5 — adicionar
// coluna `hash_prev` quando incident response evoluir.
//
// RLS por tenant_id (D002).
// ---------------------------------------------------------------------------
model AuditLog {
  id           String   @id @default(uuid(7)) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid

  // Quem fez. Null se ação foi do sistema (job, migration, etc).
  // SetNull em delete pra preservar histórico mesmo após apagar Account.
  accountId    String?  @map("account_id") @db.Uuid
  membershipId String?  @map("tenant_membership_id") @db.Uuid

  action       String   // "department.create", "agent.publish", etc.
  entityType   String   @map("entity_type") // "department", "agent", "agent_version"
  entityId     String   @map("entity_id") @db.Uuid

  // Snapshot antes/depois — opcional. Pra creates só `after`; deletes só
  // `before`; updates ambos.
  before       Json?
  after        Json?

  // Não capturados em V1 — chegam quando AccountActivity for implementado.
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")

  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account      Account?          @relation(fields: [accountId], references: [id], onDelete: SetNull)
  membership   TenantMembership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([accountId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Channel — ponto de entrada de conversa (Ontologia §11). Modelo unificado:
// voz / WhatsApp / email / webchat. Cada cliente tem N channels por tenant.
//
// Status segue ciclo provisioning → active → disabled/error. C3a entrega só
// CRUD básico (status=active no create); workflow de provisioning real
// (verificação WA, port-in DID) chega quando o data plane se integrar.
//
// `defaultRoutingRuleId` aponta pra UMA das próprias RoutingRule do channel
// (FK self-referência via channel). Nullable — channel sem rule ainda não
// roteia. RLS por tenant_id (D002).
// ---------------------------------------------------------------------------
model Channel {
  id                    String         @id @default(uuid(7)) @db.Uuid
  tenantId              String         @map("tenant_id") @db.Uuid

  tipo                  ChannelType
  identificador         String         // E.164, número WA, endereço email, etc
  nomeAmigavel          String         @map("nome_amigavel")
  status                ChannelStatus  @default(active)

  // JSON livre por tipo. Validação caso-a-caso na Server Action / por tipo.
  provisioningMetadata  Json?          @map("provisioning_metadata")

  // SIP Trunk config (only for voice_did)
  sipHost               String?        @map("sip_host")
  sipPort               Int?           @default(5060) @map("sip_port")
  sipTransport          String?        @default("udp") @map("sip_transport")
  sipUsername            String?        @map("sip_username")
  sipPassword            String?        @map("sip_password")
  sipRegister            Boolean?       @default(true) @map("sip_register")
  pbxGatewayUuid         String?        @map("pbx_gateway_uuid") @db.Uuid

  // WhatsApp fields (populated after QR scan connection)
  waBridgeUrl           String?        @map("wa_bridge_url")
  waWid                 String?        @map("wa_wid")        // e.g. "5511987654321@s.whatsapp.net"
  waPushname            String?        @map("wa_pushname")   // display name do WhatsApp

  // Default rule pra roteamento (V1.x). Self-ref opcional via RoutingRule.
  defaultRoutingRuleId  String?        @map("default_routing_rule_id") @db.Uuid

  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultRoutingRule    RoutingRule?   @relation("ChannelDefaultRule", fields: [defaultRoutingRuleId], references: [id], onDelete: SetNull)
  routingRules          RoutingRule[]
  conversations         Conversation[]

  // identificador único por tenant — evita 2 channels com mesmo DID/email/etc.
  @@unique([tenantId, tipo, identificador])
  @@index([tenantId])
  @@map("channels")
}

enum ChannelType {
  voice_did
  whatsapp
  email
  webchat

  @@map("channel_type")
}

enum ChannelStatus {
  provisioning
  active
  error
  disabled

  @@map("channel_status")
}

// ---------------------------------------------------------------------------
// RoutingRule — como conversa que entra num Channel chega num Department/Agent
// (Ontologia §12). V1 cobre só `tipo=direct`; demais (business_hours, ivr_menu,
// ai_router) ficam pra fatias futuras com UI específica.
//
// Target XOR: EXATAMENTE UM de targetDepartmentId / targetAgentId /
// targetRoutingRuleId. Constraint CHECK na migration garante (Prisma 7 não
// expressa XOR direto). targetRoutingRuleId habilita encadeamento (rule → rule).
//
// RLS por tenant_id (D002).
// ---------------------------------------------------------------------------
model RoutingRule {
  id                       String          @id @default(uuid(7)) @db.Uuid
  tenantId                 String          @map("tenant_id") @db.Uuid
  channelId                String          @map("channel_id") @db.Uuid

  tipo                     RoutingRuleType @default(direct)
  config                   Json            @default("{}")
  prioridade               Int             @default(0)
  // Template MessageTemplate.key opcional (vem quando MessageTemplate chegar).
  promptTemplateKey        String?         @map("prompt_template_key")

  // Target XOR — CHECK constraint na migration force exatamente 1 não-nulo.
  // SetNull em delete pra preservar a rule (com target null = "broken",
  // visível no portal pra reconfigurar).
  targetDepartmentId       String?         @map("target_department_id") @db.Uuid
  targetAgentId            String?         @map("target_agent_id") @db.Uuid
  targetRoutingRuleId      String?         @map("target_routing_rule_id") @db.Uuid

  createdAt                DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel                  Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  targetDepartment         Department?     @relation("RoutingRuleTargetDepartment", fields: [targetDepartmentId], references: [id], onDelete: SetNull)
  targetAgent              Agent?          @relation("RoutingRuleTargetAgent", fields: [targetAgentId], references: [id], onDelete: SetNull)
  targetRoutingRule        RoutingRule?    @relation("RoutingRuleChain", fields: [targetRoutingRuleId], references: [id], onDelete: SetNull)
  childRoutingRules        RoutingRule[]   @relation("RoutingRuleChain")

  // Channel.defaultRoutingRuleId aponta pra UMA — back-relation aqui.
  channelsAsDefault        Channel[]       @relation("ChannelDefaultRule")

  @@index([tenantId])
  @@index([channelId])
  @@index([targetDepartmentId])
  @@index([targetAgentId])
  @@map("routing_rules")
}

enum RoutingRuleType {
  direct
  business_hours
  ivr_menu
  ai_router

  @@map("routing_rule_type")
}

// ---------------------------------------------------------------------------
// KnowledgeSource — fonte de conhecimento pra RAG (Ontologia §8). Escopo
// flexível: tenant / department / agent. Retrieval em runtime combina cascata
// agent ∪ department ∪ tenant (lógica fica no data plane / runtime IA).
//
// `scopeRefId` é nullable se scope=tenant; pra department/agent aponta pra ID
// do respectivo (sem FK formal — depende do scope; validação no app).
//
// `storageRef` aponta pro original em volume/S3 (path com prefixo do tenant).
// Embeddings ficam em vector store separado (namespace por tenant), gerenciado
// pelo data plane — schema só guarda metadados.
//
// RLS por tenant_id (D002).
// ---------------------------------------------------------------------------
model KnowledgeSource {
  id                String                @id @default(uuid(7)) @db.Uuid
  tenantId          String                @map("tenant_id") @db.Uuid

  scope             KnowledgeScope
  scopeRefId        String?               @map("scope_ref_id") @db.Uuid

  tipo              KnowledgeSourceType
  nome              String
  descricao         String?
  language          String?

  status            KnowledgeSourceStatus @default(uploading)
  chunkCount        Int                   @default(0) @map("chunk_count")
  lastIndexedAt     DateTime?             @map("last_indexed_at") @db.Timestamptz(6)
  sourceMetadata    Json?                 @map("source_metadata")
  storageRef        String?               @map("storage_ref")

  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([scope, scopeRefId])
  @@map("knowledge_sources")
}

enum KnowledgeScope {
  tenant
  department
  agent

  @@map("knowledge_scope")
}

enum KnowledgeSourceType {
  upload_pdf
  upload_docx
  upload_xlsx
  upload_txt
  url_crawl
  gdrive_folder
  notion
  manual_text

  @@map("knowledge_source_type")
}

enum KnowledgeSourceStatus {
  uploading
  indexing
  ready
  error

  @@map("knowledge_source_status")
}

// ---------------------------------------------------------------------------
// AgentTool — habilitação de Tool (catálogo de função) por Agent (Ontologia §9).
//
// `toolKey` é string livre validada contra catálogo Pekiart no app
// (consultar_produto, consultar_pedido, transferir_humano, etc). V1 não
// modela Tool como tabela própria — vem só quando custom tools (Premium V2).
//
// `requiresIntegrationId` aponta pra Integration FK (a tabela Integration
// chega em fatia futura — coluna fica preparada).
// ---------------------------------------------------------------------------
model AgentTool {
  id                       String   @id @default(uuid(7)) @db.Uuid
  tenantId                 String   @map("tenant_id") @db.Uuid
  agentId                  String   @map("agent_id") @db.Uuid

  toolKey                  String   @map("tool_key")
  enabled                  Boolean  @default(true)
  config                   Json     @default("{}")
  requiresIntegrationId    String?  @map("requires_integration_id") @db.Uuid

  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent                    Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, toolKey])
  @@index([tenantId])
  @@map("agent_tools")
}

// ---------------------------------------------------------------------------
// MessageTemplate — mensagens fixas configuráveis pelo cliente, com versão
// por idioma (Ontologia §13). Resolução em runtime: cascata `agent > department
// > tenant` no `key` mais específico do `locale` da conversa, com fallback
// pro `Tenant.default_locale`.
//
// `scopeRefId` é nullable se scope=tenant; pra demais scopes aponta pra ID do
// respectivo (sem FK formal — depende do scope).
//
// V1 sem versionamento de template (sobrescreve). Se virar dor, replica pattern
// do Agent (draft + version) numa V2.
//
// RLS por tenant_id (D002).
// ---------------------------------------------------------------------------
model MessageTemplate {
  id          String                @id @default(uuid(7)) @db.Uuid
  tenantId    String                @map("tenant_id") @db.Uuid

  scope       MessageTemplateScope
  scopeRefId  String?               @map("scope_ref_id") @db.Uuid

  key         String                // ex: "out_of_hours", "ivr_welcome", "transfer_handoff"
  locale      String                // "pt-BR", "en-US", "es-ES"
  content     String

  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Unicidade: 1 template por (escopo, key, locale) dentro do tenant.
  // scopeRefId pode ser null (scope=tenant) → Postgres trata NULL como
  // distinto, então 2 rows com mesmo (tenantId, scope=tenant, key, locale)
  // PASSARIAM. Validação no app pra esse caso (raro).
  @@unique([tenantId, scope, scopeRefId, key, locale])
  @@index([tenantId])
  @@index([scope, scopeRefId])
  @@map("message_templates")
}

enum MessageTemplateScope {
  tenant
  department
  channel
  routing_rule
  agent

  @@map("message_template_scope")
}

// ===========================================================================
// CONVERSATION (Ontologia §14, D006 — modelo unificado voz/WA/email/webchat)
//
// Tabela central + 3 sub-tables 1:1 opcionais por canal + Turn (mensagens) +
// ConversationAgentHistory (transferências) + ConversationIntervention
// (intervenção humana — texto V1, voz V1.5).
//
// `tenantId` denormalizado em TODAS as filhas pra que RLS use policy padrão
// sem JOIN (mesmo pattern de AgentVersion, AuditLog).
// ===========================================================================

model Conversation {
  id                    String              @id @default(uuid(7)) @db.Uuid
  tenantId              String              @map("tenant_id") @db.Uuid
  channelId             String              @map("channel_id") @db.Uuid

  startedAt             DateTime            @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt               DateTime?           @map("ended_at") @db.Timestamptz(6)
  status                ConversationStatus  @default(active)

  // Roteamento atual — onde a conversa está no momento.
  currentAgentId        String?             @map("current_agent_id") @db.Uuid
  currentDepartmentId   String?             @map("current_department_id") @db.Uuid

  // Identificação do cliente final (telefone/email/wa-id conforme canal).
  // customerMetadata: dados extras (nome detectado, MRR, contato CRM, etc).
  customerIdentifier    String?             @map("customer_identifier")
  customerMetadata      Json?               @map("customer_metadata")

  tags                  String[]            @default([])
  summary               String?             // gerado ao fim
  languageDetected      String?             @map("language_detected")
  durationSeconds       Int?                @map("duration_seconds")
  costUsdTotal          Decimal?            @map("cost_usd_total") @db.Decimal(12, 6)

  assistanceMode        AssistanceMode      @default(ai_only) @map("assistance_mode")

  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel               Channel             @relation(fields: [channelId], references: [id], onDelete: Restrict)
  currentAgent          Agent?              @relation("ConversationCurrentAgent", fields: [currentAgentId], references: [id], onDelete: SetNull)
  currentDepartment     Department?         @relation("ConversationCurrentDepartment", fields: [currentDepartmentId], references: [id], onDelete: SetNull)

  // Sub-tables 1:1 opcionais — cada conversa tem AT MOST ONE de cada tipo
  // (geralmente só 1, do canal que originou).
  voiceData             ConversationVoiceData?
  emailData             ConversationEmailData?
  whatsappData          ConversationWhatsappData?

  turns                 Turn[]
  agentHistory          ConversationAgentHistory[]
  interventions         ConversationIntervention[]
  usageRecords          UsageRecord[]

  @@index([tenantId, startedAt(sort: Desc)])
  @@index([channelId])
  @@index([currentAgentId])
  @@index([currentDepartmentId])
  @@map("conversations")
}

enum ConversationStatus {
  active
  ended
  abandoned
  escalated

  @@map("conversation_status")
}

enum AssistanceMode {
  ai_only
  human_observing
  human_assisted
  human_takeover

  @@map("assistance_mode")
}

// ---------------------------------------------------------------------------
// Sub-table específica de canal — voz (DID SIP).
// 1:1 opcional com Conversation. Cascateia delete da parent.
// tenant_id denormalizado pra RLS sem JOIN.
// ---------------------------------------------------------------------------
model ConversationVoiceData {
  conversationId   String       @id @map("conversation_id") @db.Uuid
  tenantId         String       @map("tenant_id") @db.Uuid

  recordingRef     String?      @map("recording_ref")
  sipCallId        String?      @map("sip_call_id")
  callerIdName     String?      @map("caller_id_name")
  hangupCause      String?      @map("hangup_cause")

  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("conversation_voice_data")
}

model ConversationEmailData {
  conversationId   String       @id @map("conversation_id") @db.Uuid
  tenantId         String       @map("tenant_id") @db.Uuid

  subject          String?
  rootMessageId    String?      @map("root_message_id")    // RFC 5322 Message-Id
  references       String[]     @default([])               // chain de message_ids
  fromAddress      String?      @map("from_address")

  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("conversation_email_data")
}

model ConversationWhatsappData {
  conversationId             String       @id @map("conversation_id") @db.Uuid
  tenantId                   String       @map("tenant_id") @db.Uuid

  waChatId                   String?      @map("wa_chat_id")
  // Janela de 24h da Meta — fora dela, só template aprovado.
  businessInitiatedWindowUntil DateTime?  @map("business_initiated_window_until") @db.Timestamptz(6)
  lastTemplateUsedId         String?      @map("last_template_used_id") @db.Uuid

  conversation               Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("conversation_whatsapp_data")
}

// ---------------------------------------------------------------------------
// ConversationAgentHistory — registra cada transferência de agent dentro
// da conversa (ex.: N1 → N2). fromAgentId nullable na primeira ocorrência.
// ---------------------------------------------------------------------------
model ConversationAgentHistory {
  id              String       @id @default(uuid(7)) @db.Uuid
  conversationId  String       @map("conversation_id") @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid

  fromAgentId     String?      @map("from_agent_id") @db.Uuid
  toAgentId       String       @map("to_agent_id") @db.Uuid

  at              DateTime     @default(now()) @db.Timestamptz(6)
  reason          String?

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromAgent       Agent?       @relation("ConversationAgentHistoryFrom", fields: [fromAgentId], references: [id], onDelete: SetNull)
  toAgent         Agent        @relation("ConversationAgentHistoryTo", fields: [toAgentId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([conversationId])
  @@map("conversation_agent_history")
}

// ---------------------------------------------------------------------------
// ConversationIntervention — operador humano entra na conversa.
// Texto: V1; voz (barge-in/takeover SIP): V1.5.
// ---------------------------------------------------------------------------
model ConversationIntervention {
  id                 String           @id @default(uuid(7)) @db.Uuid
  conversationId     String           @map("conversation_id") @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  operatorAccountId  String           @map("operator_account_id") @db.Uuid

  modeEntered        InterventionMode @map("mode_entered")
  startedAt          DateTime         @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt            DateTime?        @map("ended_at") @db.Timestamptz(6)
  reason             String?

  conversation       Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // SetNull em delete pra preservar histórico mesmo se Account for apagada.
  operatorAccount    Account          @relation(fields: [operatorAccountId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([conversationId])
  @@map("conversation_intervention")
}

enum InterventionMode {
  observing
  assisted
  takeover

  @@map("intervention_mode")
}

// ---------------------------------------------------------------------------
// Turn — evento individual da conversa (Ontologia §15). Em texto = uma
// mensagem; em voz = um turn de fala (transcrito) com áudio opcional.
//
// `actorAccountId` preenchido quando speaker=human_operator (preserva auditoria
// de intervenção). NÃO confundir com `currentAgentId` da conversation.
// ---------------------------------------------------------------------------
model Turn {
  id              String       @id @default(uuid(7)) @db.Uuid
  conversationId  String       @map("conversation_id") @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid

  speaker         TurnSpeaker
  contentText     String?      @map("content_text")
  contentAudioRef String?      @map("content_audio_ref")
  timestamp       DateTime     @default(now()) @db.Timestamptz(6)
  latencyMs       Int?         @map("latency_ms")

  // Quando agente invoca tool: tool_call (input) e tool_result (output).
  toolCall        Json?        @map("tool_call")
  toolResult      Json?        @map("tool_result")

  tokensIn        Int?         @map("tokens_in")
  tokensOut       Int?         @map("tokens_out")

  actorAccountId  String?      @map("actor_account_id") @db.Uuid

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorAccount    Account?     @relation(fields: [actorAccountId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([conversationId, timestamp])
  @@map("turns")
}

enum TurnSpeaker {
  customer
  agent
  system
  tool
  human_operator

  @@map("turn_speaker")
}

// ---------------------------------------------------------------------------
// SecurityEvent — eventos com viés de segurança, separados do AuditLog
// (Ontologia §21, seguranca.md §5.7).
//
// AuditLog cobre ações privilegiadas legítimas. SecurityEvent cobre sinais
// que MERECEM INVESTIGAÇÃO: brute force, MFA fail, permissão negada, secret
// access anômalo, login fora do horário, etc.
//
// `tenantId` nullable: eventos cross-tenant (login pré-tenant, signup) ficam
// com tenant_id=null. RLS filtra esses pra `app_user` (visíveis só pra admin
// via prismaAdmin / sem RLS) — pra portal, vê só os tenant-scoped.
//
// `severity >= medium` deve disparar email/alert via runbook (seguranca.md §7).
//
// Hash chain (anti-tampering, seguranca.md §5.7) fica pra V1.5 — adicionar
// coluna `hash_prev` quando incident response evoluir.
// ---------------------------------------------------------------------------
model SecurityEvent {
  id              String              @id @default(uuid(7)) @db.Uuid

  // Nullable: eventos pré-tenant (login fail no signin sem tenant ativo,
  // signup) não têm tenant. Visíveis só pra admin Pekiart (sem RLS).
  tenantId        String?             @map("tenant_id") @db.Uuid
  accountId       String?             @map("account_id") @db.Uuid

  severity        SecuritySeverity    @default(info)
  category        SecurityCategory
  eventType       String              @map("event_type") // ex.: "login_fail", "lockout_triggered"
  description     String?

  ipAddress       String?             @map("ip_address")
  userAgent       String?             @map("user_agent")
  metadata        Json?

  // Investigação:
  resolvedAt      DateTime?           @map("resolved_at") @db.Timestamptz(6)
  resolutionNote  String?             @map("resolution_note")

  // Cross-link com AuditLog quando faz sentido (ex.: "permissão negada"
  // que tentou fazer X — linka pra audit que registrou a tentativa).
  linkedAuditLogId String?            @map("linked_audit_log_id") @db.Uuid

  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant          Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account         Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([accountId])
  @@index([severity, category])
  @@map("security_events")
}

enum SecuritySeverity {
  info
  low
  medium
  high
  critical

  @@map("security_severity")
}

enum SecurityCategory {
  authn
  authz
  integration
  upload
  data_access
  config_change
  secret_access
  rate_limit
  anomaly

  @@map("security_category")
}

// ---------------------------------------------------------------------------
// UsageRecord (Ontologia §16) — granularidade fina de uso/custo pra billing
// e relatórios. Escrito pelo runtime (bridge-ia, wa-bridge, mailer) conforme
// conversas rodam. Portal só LÊ.
//
// `tipo` é string livre pra evitar acoplar enum a cada novo provedor:
//   - gemini_audio_minutes
//   - gemini_tokens_in / gemini_tokens_out
//   - whatsapp_message_session / whatsapp_message_template
//   - email_sent
//   - storage_gb_day
//   - sip_call_minutes (futuro)
//
// Agregações por dia/mês ficam em views materializadas (V1.5).
//
// RLS por tenant_id (D002).
// ---------------------------------------------------------------------------
model UsageRecord {
  id              String        @id @default(uuid(7)) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid

  // Opcionais — granularidade: alguns custos são por conversa (audio
  // minutes), outros por agente (tokens), outros do tenant (storage).
  conversationId  String?       @map("conversation_id") @db.Uuid
  agentId         String?       @map("agent_id") @db.Uuid

  tipo            String
  quantity        Decimal       @db.Decimal(18, 6)
  unitCostUsd     Decimal       @map("unit_cost_usd") @db.Decimal(12, 8)
  totalCostUsd    Decimal       @map("total_cost_usd") @db.Decimal(14, 6)

  recordedAt      DateTime      @default(now()) @map("recorded_at") @db.Timestamptz(6)

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  agent           Agent?        @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([tenantId, recordedAt(sort: Desc)])
  @@index([tenantId, tipo, recordedAt(sort: Desc)])
  @@index([conversationId])
  @@index([agentId])
  @@map("usage_records")
}
