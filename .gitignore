# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code runtime — locks de tarefa agendada não devem ser versionados.
.claude/scheduled_tasks.lock

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDEs / editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo

# Testes (extras)
playwright-report/
test-results/

# Prisma generated
prisma/generated/

# Cache
.cache/
.turbo/
.eslintcache

# Claude Code overrides locais (não compartilhar entre devs/máquinas)
.claude/settings.local.json

/src/generated/prisma
scheduled_tasks.lock
